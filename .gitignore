# === My Scripts ===
scripts/custom/
# Ignore schedulers by default (many .bat files hardcode local paths),
# but track the portable automation/ folder (paths derived from __file__, no secrets).
scripts/schedulers/*
!scripts/schedulers/automation/
!scripts/schedulers/automation/**
scripts/schedulers/automation/__pycache__/

# === Repos ===
/repos/
# aX Platform CLI config (contains token)
.ax/
