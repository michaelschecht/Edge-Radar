# Edge-Radar Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control


# ┌─────────────────────────────────────────────────────────────────────┐
# │  KALSHI API (required)                                             │
# │  Your Kalshi credentials for placing bets and reading positions.   │
# │  Sign up at kalshi.com, then generate an API key in Settings.      │
# └─────────────────────────────────────────────────────────────────────┘

# Your Kalshi API key (found in Kalshi account Settings > API)
KALSHI_API_KEY=

# Path to your RSA private key file used to sign API requests.
# Generate a key pair, upload the public key to Kalshi, and store the
# private key locally. Default path: keys/live/kalshi_private.key
KALSHI_PRIVATE_KEY_PATH=keys/live/kalshi_private.key

# Kalshi API base URL. No need to change unless Kalshi moves endpoints.
KALSHI_BASE_URL=https://api.elections.kalshi.com/trade-api/v2


# ┌─────────────────────────────────────────────────────────────────────┐
# │  MARKET DATA — External Odds & Pricing                            │
# │  Used by the edge detector to compare Kalshi prices against        │
# │  sportsbook consensus odds and find mispriced markets.             │
# └─────────────────────────────────────────────────────────────────────┘

# The Odds API — provides real-time sportsbook odds for edge detection.
# Get free keys at https://the-odds-api.com (free tier: 500 req/month per key).
# Comma-separated list. The system automatically rotates to the next key
# when one runs out of monthly requests, so adding more keys = more scans.
ODDS_API_KEYS=
# Example with multiple keys for higher scan capacity:
# ODDS_API_KEYS=key1,key2,key3


# ┌─────────────────────────────────────────────────────────────────────┐
# │  RISK LIMITS — Position Sizing & Loss Controls                     │
# │  These guard against oversized bets and runaway losses.            │
# │  All dollar amounts are in USD. Adjust to match your bankroll.     │
# └─────────────────────────────────────────────────────────────────────┘

# The smallest bet the system will ever place, regardless of what Kelly
# sizing calculates. Acts as a floor so tiny-edge bets don't round to $0.
# Raise this if you want a higher minimum stake per bet.
UNIT_SIZE=1.00

# Fraction of full Kelly Criterion used for bet sizing. Full Kelly (1.0)
# maximizes long-run growth but is extremely volatile. Quarter-Kelly (0.25)
# is the industry standard for a smoother equity curve. Lower = more
# conservative sizing, higher = more aggressive. Range: 0.01 to 1.0.
# At runtime, this is further divided by the number of bets in a batch
# to prevent over-leveraging when many bets fire at once.
KELLY_FRACTION=0.25

# Absolute maximum dollar amount for a single sports bet (NBA, MLB, etc.).
# Even if Kelly sizing suggests a larger bet, the system caps at this value.
# This is a hard safety limit — it cannot be overridden at runtime.
MAX_BET_SIZE_SPORTS=50

# Same as above but for prediction market positions (crypto, weather, S&P).
# Higher default because prediction markets often have longer time horizons
# and more data sources for edge validation.
MAX_BET_SIZE_PREDICTION=100

# If your cumulative losses for the day reach this amount, the system
# halts ALL new betting for the remainder of the day. Existing positions
# are not closed — they ride to settlement. Resets at midnight ET.
MAX_DAILY_LOSS=250

# Maximum number of unsettled positions allowed at any time. Once this
# limit is reached, no new bets are placed until existing ones settle.
# Prevents over-diversification that dilutes edge and makes tracking hard.
MAX_OPEN_POSITIONS=50

# Maximum positions allowed on the same game or event. Prevents
# concentration risk — e.g., betting the spread, total, AND moneyline
# on the same Lakers game. Set to 1 to allow only one bet per game.
MAX_PER_EVENT=2

# Maximum single bet as a multiple of the batch median cost. Prevents one
# high-edge, low-price bet from dominating a batch. E.g., 3.0 means no
# single bet can cost more than 3x the median bet in the same run.
MAX_BET_RATIO=3.0

# Maximum percentage of your total bankroll that a single position can
# represent. 0.20 = 20%. This is a risk gate — any bet that would push
# a single position past this threshold is rejected. Protects against
# one bad bet wiping out a large chunk of your bankroll.
MAX_POSITION_CONCENTRATION=0.20

# Minimum required edge (as a decimal) for the system to consider a bet.
# Edge = (your estimated probability) - (implied probability from Kalshi price).
# 0.03 = 3% edge. Bets below this threshold are skipped entirely.
# Higher = fewer but higher-quality bets. Lower = more volume but thinner edge.
MIN_EDGE_THRESHOLD=0.03

# Minimum composite score (0-10 scale) for a bet to pass the quality filter.
# The composite score combines edge size, data source agreement, line movement
# signals, team stats, and other factors into a single number. Opportunities
# scoring below this are filtered out of scan results and cannot execute.
MIN_COMPOSITE_SCORE=6.0

# Minimum confidence level required for execution. Three tiers:
#   low    — fewer data sources agree, wider uncertainty
#   medium — majority of signals align, reasonable certainty
#   high   — strong cross-source agreement, tight uncertainty
# Set to "high" if you only want the strongest signals to execute.
MIN_CONFIDENCE=medium


# ┌─────────────────────────────────────────────────────────────────────┐
# │  SYSTEM — Execution Mode & Logging                                 │
# └─────────────────────────────────────────────────────────────────────┘

# When true, the system does everything EXCEPT place real bets: it scans
# markets, calculates edge, sizes positions, and logs what it WOULD have
# done. Perfect for testing and backtesting. Set to false only when you
# are ready to bet real money. Always start with true.
DRY_RUN=true

# Controls how much detail appears in console output and log files.
# Options: DEBUG (very verbose — API calls, raw data), INFO (normal),
# WARNING (only problems), ERROR (only failures). Use DEBUG when
# troubleshooting scan issues or API errors.
LOG_LEVEL=INFO


# ┌─────────────────────────────────────────────────────────────────────┐
# │  OPTIONAL — Future Integrations (not yet implemented)              │
# │  Uncomment and fill in when these platforms are added.             │
# └─────────────────────────────────────────────────────────────────────┘
# POLYMARKET_PRIVATE_KEY=
# ALPACA_API_KEY=
# ALPACA_SECRET_KEY=
# ALPACA_BASE_URL=https://paper-api.alpaca.markets
# COINBASE_API_KEY=
# COINBASE_API_SECRET=
# BRAVE_API_KEY=
# TAVILY_API_KEY=
# AX_API_KEY=
# AX_WORKSPACE_ID=
# DATABASE_URL=sqlite:///data/finagent.db
