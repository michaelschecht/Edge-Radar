# FinAgent Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# === KALSHI (required) ===
KALSHI_API_KEY=
KALSHI_PRIVATE_KEY_PATH=keys/live/kalshi_private.key
KALSHI_BASE_URL=https://api.elections.kalshi.com/trade-api/v2

# === MARKET DATA ===
# Comma-separated list of Odds API keys. Rotates automatically when one is exhausted.
# Get keys at https://the-odds-api.com (free tier: 500 req/month per key)
ODDS_API_KEYS=
# Add multiple keys for more capacity:
# ODDS_API_KEYS=key1,key2,key3

# === RISK LIMITS ===
UNIT_SIZE=1.00                      # Default dollar amount per bet
MAX_BET_SIZE_PREDICTION=5           # Hard cap per single bet
MAX_DAILY_LOSS=250                  # Stop all betting if daily P&L hits this
MAX_OPEN_POSITIONS=10               # Max concurrent positions
MIN_EDGE_THRESHOLD=0.03             # 3% minimum edge
MIN_COMPOSITE_SCORE=6.0             # Minimum opportunity score (0-10)
MIN_CONFIDENCE=medium               # Minimum confidence: low, medium, high
KELLY_FRACTION=0.25                 # Quarter-Kelly sizing factor

# === SYSTEM ===
DRY_RUN=true                        # Set to false for live execution
LOG_LEVEL=INFO                      # DEBUG for verbose output

# === SCHEDULERS ===
# Each scheduler has: ENABLED, INTERVAL_MINUTES, FILTERS, MAX_BETS, PREDICTION
# Set ENABLED=true to activate. See docs/schedulers/SCHEDULER_GUIDE.md

# Sports
SCHED_NBA_ENABLED=false
SCHED_NBA_INTERVAL_MINUTES=10
SCHED_NBA_FILTERS=KXNBA
SCHED_NBA_MAX_BETS=3

SCHED_NHL_ENABLED=false
SCHED_NHL_INTERVAL_MINUTES=15
SCHED_NHL_FILTERS=KXNHL
SCHED_NHL_MAX_BETS=3

SCHED_MLB_ENABLED=false
SCHED_MLB_INTERVAL_MINUTES=15
SCHED_MLB_FILTERS=KXMLB
SCHED_MLB_MAX_BETS=3

SCHED_NFL_ENABLED=false
SCHED_NFL_INTERVAL_MINUTES=15
SCHED_NFL_FILTERS=KXNFL
SCHED_NFL_MAX_BETS=3

SCHED_NCAA_ENABLED=false
SCHED_NCAA_INTERVAL_MINUTES=15
SCHED_NCAA_FILTERS=KXNCAA
SCHED_NCAA_MAX_BETS=3

SCHED_SOCCER_ENABLED=false
SCHED_SOCCER_INTERVAL_MINUTES=20
SCHED_SOCCER_FILTERS=KXSOCCER
SCHED_SOCCER_MAX_BETS=3

# Prediction markets
SCHED_CRYPTO_ENABLED=false
SCHED_CRYPTO_INTERVAL_MINUTES=30
SCHED_CRYPTO_FILTERS=crypto
SCHED_CRYPTO_MAX_BETS=5
SCHED_CRYPTO_PREDICTION=true

SCHED_WEATHER_ENABLED=false
SCHED_WEATHER_INTERVAL_MINUTES=60
SCHED_WEATHER_FILTERS=weather
SCHED_WEATHER_MAX_BETS=3
SCHED_WEATHER_PREDICTION=true

SCHED_SPX_ENABLED=false
SCHED_SPX_INTERVAL_MINUTES=30
SCHED_SPX_FILTERS=spx
SCHED_SPX_MAX_BETS=3
SCHED_SPX_PREDICTION=true

# === OPTIONAL: Future integrations (not yet implemented) ===
# POLYMARKET_PRIVATE_KEY=
# ALPACA_API_KEY=
# ALPACA_SECRET_KEY=
# ALPACA_BASE_URL=https://paper-api.alpaca.markets
# COINBASE_API_KEY=
# COINBASE_API_SECRET=
# BRAVE_API_KEY=
# TAVILY_API_KEY=
# AX_API_KEY=
# AX_WORKSPACE_ID=
# DATABASE_URL=sqlite:///data/finagent.db
