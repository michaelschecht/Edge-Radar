# FinAgent Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# === MARKET DATA ===
ODDS_API_KEY=
RAPIDAPI_KEY=
SPORTRADAR_API_KEY=

# === PREDICTION MARKETS ===
POLYMARKET_PRIVATE_KEY=
KALSHI_API_KEY=
KALSHI_API_SECRET=

# === STOCK/OPTIONS TRADING ===
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# === CRYPTO ===
COINBASE_API_KEY=
COINBASE_API_SECRET=

# === RESEARCH ===
BRAVE_API_KEY=
TAVILY_API_KEY=

# === INFRASTRUCTURE ===
AX_API_KEY=
AX_WORKSPACE_ID=
DATABASE_URL=sqlite:///data/finagent.db

# === SYSTEM ===
DRY_RUN=true
MONITOR_INTERVAL=5
LOG_LEVEL=INFO
MAX_BET_SIZE_SPORTS=50
MAX_BET_SIZE_PREDICTION=100
MAX_POSITION_STOCKS=500
MAX_DAILY_LOSS=250
MAX_OPEN_POSITIONS=10
MIN_EDGE_THRESHOLD=0.03
MAX_PORTFOLIO_RISK_PCT=0.02
