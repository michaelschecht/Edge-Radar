# Edge-Radar Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# See detailed descriptions below each section

# === API KEYS (required) ===
KALSHI_API_KEY=                     # Kalshi account Settings > API
KALSHI_PRIVATE_KEY_PATH=keys/live/kalshi_private.key  # RSA private key for signing requests
KALSHI_BASE_URL=https://api.elections.kalshi.com/trade-api/v2
ODDS_API_KEYS=                      # Comma-separated. Free keys at https://the-odds-api.com

# === RISK LIMITS ===
UNIT_SIZE=1.00                      # Minimum dollar amount per bet (Kelly floor). Override with --unit-size flag.
KELLY_FRACTION=0.25                 # Kelly sizing multiplier (0.25 = quarter-Kelly). Divided by batch size at runtime.
MAX_BET_SIZE=100                    # Hard cap in USD for any single bet, regardless of Kelly sizing
MAX_DAILY_LOSS=250                  # Stop all betting if daily P&L hits this
MAX_OPEN_POSITIONS=50               # Max unsettled positions at once
MAX_PER_EVENT=2                     # Max bets per single game/event
MAX_BET_RATIO=3.0                   # Max single bet as multiple of batch median cost
MIN_EDGE_THRESHOLD=0.03             # Minimum edge required (0.03 = 3%). Global default.
MIN_COMPOSITE_SCORE=6.0             # Minimum opportunity score (0-10)
KELLY_EDGE_CAP=0.15                 # Soft-cap edge for Kelly sizing (15%). Above this, edge decays.
KELLY_EDGE_DECAY=0.5                # Decay factor above KELLY_EDGE_CAP (0.5 = half weight on excess)

# Per-sport edge thresholds (optional). Uncomment to override the global floor
# for a specific sport. Defaults reflect 2026-04-18 calibration: NBA and NCAAB
# are loss-making at the 3% global floor and need a higher bar.
MIN_EDGE_THRESHOLD_NBA=0.08         # NBA: -15% ROI post-baseline at 3% floor
MIN_EDGE_THRESHOLD_NCAAB=0.10       # NCAAB: 12% WR, -62% ROI in 14-day window

# Series dedup: reject a bet on a matchup already bet within this many hours.
# 0 disables. Set after 2026-04-18 when same-matchup bets on consecutive nights
# (LA Angels @ NY Yankees Apr 13/14/15) produced compounding losses.
SERIES_DEDUP_HOURS=48
# MIN_EDGE_THRESHOLD_MLB=0.03
# MIN_EDGE_THRESHOLD_NHL=0.03
# MIN_EDGE_THRESHOLD_NFL=0.03
# MIN_EDGE_THRESHOLD_NCAAF=0.03
# MIN_EDGE_THRESHOLD_MLS=0.03
# MIN_EDGE_THRESHOLD_SOCCER=0.03

# === SYSTEM ===
DRY_RUN=true                        # Set to false for live execution
LOG_LEVEL=INFO                      # DEBUG for verbose output


# ─────────────────────────────────────────────────────────────────────────────
# DETAILED DESCRIPTIONS
# ─────────────────────────────────────────────────────────────────────────────
#
# KALSHI_API_KEY
#   Your Kalshi API key. Sign up at kalshi.com, then generate a key in
#   Settings > API.
#
# KALSHI_PRIVATE_KEY_PATH
#   Path to your RSA private key file used to sign API requests. Generate a
#   key pair, upload the public key to Kalshi, and store the private key
#   locally. Default: keys/live/kalshi_private.key
#
# ODDS_API_KEYS
#   The Odds API provides real-time sportsbook odds for edge detection.
#   Free tier: 500 req/month per key. Comma-separated list — the system
#   automatically rotates to the next key when one hits its rate limit.
#   More keys = more scans per month.
#   Example: ODDS_API_KEYS=key1,key2,key3
#
# UNIT_SIZE
#   The smallest bet the system will ever place. Acts as a floor so
#   tiny-edge bets don't round to $0. Overridable per-run with --unit-size.
#
# KELLY_FRACTION
#   Fraction of full Kelly Criterion used for bet sizing. Full Kelly (1.0)
#   maximizes long-run growth but is extremely volatile. Quarter-Kelly (0.25)
#   is the industry standard for a smoother equity curve. At runtime, this
#   is further divided by the number of bets in the batch to prevent
#   over-leveraging when many bets fire at once.
#
# MAX_BET_SIZE
#   Absolute hard cap per single bet. Even if Kelly sizing suggests more,
#   the system caps at this value. Cannot be overridden at runtime.
#
# MAX_DAILY_LOSS
#   If your cumulative losses for the day reach this amount, the system
#   halts ALL new betting for the remainder of the day. Existing positions
#   ride to settlement. Resets at midnight ET.
#
# MAX_OPEN_POSITIONS
#   Maximum unsettled positions allowed at any time. Once reached, no new
#   bets are placed until existing ones settle.
#
# MAX_PER_EVENT
#   Maximum positions on the same game or event. Prevents concentration
#   risk (e.g., betting spread, total, AND moneyline on the same game).
#   Set to 1 to allow only one bet per game.
#
# MAX_BET_RATIO
#   Prevents one high-edge, low-price bet from dominating a batch. E.g.,
#   3.0 means no single bet can cost more than 3x the median bet in the
#   same run. Only scales down outliers — other bets stay unchanged.
#
# MIN_EDGE_THRESHOLD
#   Minimum edge (as decimal) for the system to consider a bet.
#   Edge = (estimated probability) - (implied probability from Kalshi price).
#   0.03 = 3%. Higher = fewer but higher-quality bets. Global default used
#   for sports without a per-sport override.
#
# MIN_EDGE_THRESHOLD_<SPORT>
#   Optional per-sport override of the global edge floor. Supported sports:
#   MLB, NBA, NHL, NFL, NCAAB, NCAAF, MLS, SOCCER. Read at import; unlisted
#   sports fall back to MIN_EDGE_THRESHOLD. Defaults set in this template
#   reflect 2026-04-18 calibration: NBA and NCAAB are loss-making at 3%,
#   while NHL (+100% ROI post-baseline) stays on the global floor.
#
# SERIES_DEDUP_HOURS
#   Reject a new bet if the same matchup (sport + team pair, date-agnostic)
#   was already bet within this many hours — Gate 7. Catches series-level
#   correlation that the within-batch dedup can't see. 0 disables. The
#   check reads the local trade log, so dry-run runs don't count.
#   Default 48h covers typical 3-game MLB/NHL series without blocking the
#   next series. Raise to 72h for sweep-series or weekly events; lower to
#   24h if you want only strict back-to-back suppression.
#
# MIN_COMPOSITE_SCORE
#   Minimum composite score (0-10) to pass the quality filter. Combines
#   edge size, confidence, data source agreement, line movement signals,
#   team stats, and other factors. Opportunities below this are skipped.
#
# KELLY_EDGE_CAP / KELLY_EDGE_DECAY
#   Soft-cap applied ONLY to the edge value used inside the Kelly sizing
#   calculation. Raw edge still drives gates, reports, and trade rationale.
#   Above KELLY_EDGE_CAP, the excess is multiplied by KELLY_EDGE_DECAY:
#       trusted = cap + (edge - cap) * decay     if edge > cap
#       trusted = edge                            otherwise
#   Rationale: post-baseline calibration (2026-04-18) shows claimed edges
#   >=25% realize -35% ROI while 10-15% claimed edges realize +127%. Large
#   edges are systematically overstated; this downsizes bets on likely fakes
#   without eliminating them. Defaults: cap=0.15, decay=0.5 (e.g., a claimed
#   25% edge sizes like 20%; a 35% edge sizes like 25%).
#
# DRY_RUN
#   When true, the system does everything EXCEPT place real bets: scans,
#   calculates edge, sizes positions, and logs what it WOULD have done.
#   Perfect for testing. Set to false only when ready to bet real money.
#
# LOG_LEVEL
#   Controls console and log file verbosity. Options: DEBUG (very verbose),
#   INFO (normal), WARNING (only problems), ERROR (only failures).


# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL — Future Integrations (not yet implemented)
# ─────────────────────────────────────────────────────────────────────────────
