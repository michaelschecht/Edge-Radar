# Edge-Radar Environment Variables
# Copy this file to .env and fill in your values. NEVER commit .env.
#
# ─────────────────────────────────────────────────────────────────────────────
# QUICK START — the 5 things most users ever touch:
#   1. KALSHI_API_KEY + KALSHI_PRIVATE_KEY_PATH   (required, live trading)
#   2. ODDS_API_KEYS                              (required, sports edge detection)
#   3. UNIT_SIZE                                  (default bet size)
#   4. MAX_DAILY_LOSS + MAX_OPEN_POSITIONS        (your safety rails)
#   5. DRY_RUN                                    (keep true until you're ready)
# Everything else has calibrated defaults. See DETAILED DESCRIPTIONS below for
# the "why" behind each knob before tuning.
# ─────────────────────────────────────────────────────────────────────────────


# === 1. API CREDENTIALS (required) ===========================================
KALSHI_API_KEY=
KALSHI_PRIVATE_KEY_PATH=keys/live/kalshi_private.key
KALSHI_BASE_URL=https://api.elections.kalshi.com/trade-api/v2
ODDS_API_KEYS=                      # Comma-separated. Free keys: https://the-odds-api.com


# === 2. CORE LIMITS — main safety rails ======================================
UNIT_SIZE=1.00                      # Default bet size (USD). Overridable via --unit-size.
MAX_BET_SIZE=100                    # Hard cap per single bet (USD).
MAX_DAILY_LOSS=250                  # Halt new bets when today's P&L hits -$250.
MAX_OPEN_POSITIONS=50               # Max unsettled positions at once.
MAX_PER_EVENT=2                     # Max bets per single game/event.


# === 3. REJECT GATES — quality bar every opportunity must clear ==============
MIN_EDGE_THRESHOLD=0.03             # Min edge (3%). Global; per-sport overrides in section 5.
MIN_COMPOSITE_SCORE=6.0             # Min opportunity score (0-10).
MIN_CONFIDENCE=medium               # low | medium | high. Gate 4.5 (R3).
SERIES_DEDUP_HOURS=48               # Reject same matchup bet within this window. 0 disables.

# NO-side favorite guard (R1, Gate 4.6). Reject NO bets on heavy favorites
# unless edge AND confidence both clear a much higher bar.
NO_SIDE_FAVORITE_THRESHOLD=0.25     # Below this NO-side price, the gate applies.
NO_SIDE_MIN_EDGE=0.25               # Required edge when below threshold (also needs confidence=high).


# === 4. SIZING — Kelly with soft-cap and dampeners ===========================
KELLY_FRACTION=0.25                 # Quarter-Kelly. Divided by batch size at runtime.
KELLY_EDGE_CAP=0.15                 # Soft-cap on edge used in Kelly (raw edge unchanged in gates).
KELLY_EDGE_DECAY=0.5                # Decay on edge above the cap. 0.5 = half weight on excess.
MAX_BET_RATIO=3.0                   # Max single bet as multiple of batch median cost.

# NO-side half-Kelly dampener (R1). Complements the reject gate above: NO bets
# that clear gate 4.6 but are still on moderate favorites get downsized.
NO_SIDE_KELLY_PRICE_FLOOR=0.35      # Below this NO-side price, apply multiplier.
NO_SIDE_KELLY_MULTIPLIER=0.5        # 0.5 = half-Kelly. Set to 1.0 to disable.


# === 5. PER-SPORT EDGE FLOORS (optional overrides) ===========================
# Calibration (2026-04-18) showed NBA (-15% ROI) and NCAAB (-62% ROI) losing at
# the 3% global floor. NHL (+100%) stays on the global floor — do not raise.
# Supported: MLB, NBA, NHL, NFL, NCAAB, NCAAF, MLS, SOCCER.
MIN_EDGE_THRESHOLD_NBA=0.08
MIN_EDGE_THRESHOLD_NCAAB=0.10
# MIN_EDGE_THRESHOLD_MLB=0.03
# MIN_EDGE_THRESHOLD_NHL=0.03
# MIN_EDGE_THRESHOLD_NFL=0.03
# MIN_EDGE_THRESHOLD_NCAAF=0.03
# MIN_EDGE_THRESHOLD_MLS=0.03
# MIN_EDGE_THRESHOLD_SOCCER=0.03


# === 6. SYSTEM ===============================================================
DRY_RUN=true                        # Set false for live execution.
LOG_LEVEL=INFO                      # DEBUG | INFO | WARNING | ERROR.


# ─────────────────────────────────────────────────────────────────────────────
# DETAILED DESCRIPTIONS — the "why" behind each knob
# ─────────────────────────────────────────────────────────────────────────────
# Only the non-obvious ones. Variables with a self-explanatory inline comment
# above are omitted here.

# --- API credentials ---------------------------------------------------------
#
# KALSHI_PRIVATE_KEY_PATH
#   Path to your RSA private key used to sign API requests. Upload the public
#   half to Kalshi Settings > API; keep the private half local.
#
# ODDS_API_KEYS
#   Free tier: 500 req/month per key. The system rotates automatically when a
#   key hits its quota — more keys = more scans per month. Format: key1,key2,key3.

# --- Sizing ------------------------------------------------------------------
#
# UNIT_SIZE
#   Floor below which Kelly cannot shrink. Keeps tiny-edge bets from rounding
#   to $0. Overridable per-run with --unit-size.
#
# KELLY_FRACTION
#   Fraction of full Kelly. Quarter-Kelly (0.25) is the industry standard for
#   a smoother equity curve. At runtime, further divided by batch size to avoid
#   over-leveraging when many bets fire at once.
#
# MAX_BET_RATIO
#   Prevents one high-edge, low-price bet from dominating a batch. 3.0 means
#   no single bet can cost more than 3× the median bet in the same run. Only
#   scales down outliers — other bets stay unchanged.
#
# KELLY_EDGE_CAP / KELLY_EDGE_DECAY
#   Soft-cap applied ONLY inside the Kelly calculation. Raw edge still drives
#   gate 3, composite score, reports, and trade rationale.
#       trusted = edge                            if edge <= cap
#       trusted = cap + (edge - cap) * decay      if edge >  cap
#   Rationale: post-baseline calibration (2026-04-18) showed claimed edges
#   >=25% realize -35% ROI while 10-15% edges realize +127%. Big claimed edges
#   are systematically overstated; this downsizes likely fakes without
#   eliminating them. Defaults: a claimed 25% edge sizes like 20%; 35% like 25%.

# --- Reject gates ------------------------------------------------------------
#
# MIN_EDGE_THRESHOLD
#   Edge = (estimated probability) - (implied probability from Kalshi price).
#   Global default when no per-sport override is set. Higher = fewer but
#   higher-quality bets.
#
# MIN_COMPOSITE_SCORE
#   Weighted score combining edge, confidence, liquidity, data-source
#   agreement, line movement, and team stats. Opportunities below this are
#   skipped regardless of edge.
#
# MIN_CONFIDENCE
#   Gate 4.5 (R3, 2026-04-21). Rejects any opportunity whose confidence ranks
#   below this floor. Two review windows (2026-04-18, 2026-04-21) showed low
#   confidence at 0W-3L / -105% ROI. Set to "low" to disable; "high" for the
#   strictest filter.
#
# NO_SIDE_FAVORITE_THRESHOLD / NO_SIDE_MIN_EDGE
#   Gate 4.6 (R1, 2026-04-21). NO bets on heavy favorites need edge >=
#   NO_SIDE_MIN_EDGE AND confidence=high. Rationale: every high-edge loser
#   (13 of 13) in the 14-day window was a NO bet on a heavy favorite; NO at
#   >=20% edge realized 31% WR / -33% ROI. Set NO_SIDE_FAVORITE_THRESHOLD=0
#   to disable the gate entirely.
#
# NO_SIDE_KELLY_PRICE_FLOOR / NO_SIDE_KELLY_MULTIPLIER
#   Sizing dampener (R1). NO bets priced below the floor are sized at
#   MULTIPLIER of normal Kelly (default half-Kelly below 35¢). Catches bets
#   that clear gate 4.6 but still lean into the overstated-edge pattern. Set
#   NO_SIDE_KELLY_MULTIPLIER=1.0 to disable.
#
# SERIES_DEDUP_HOURS
#   Gate 7 (C5, 2026-04-18). Reject a new bet if the same matchup (sport +
#   team pair, date-agnostic) was already bet within this many hours. Catches
#   series-level correlation the within-batch dedup can't see. Reads the
#   local trade log, so dry-run runs don't count. Default 48h covers typical
#   3-game MLB/NHL series; raise to 72h for weekly events.

# --- System ------------------------------------------------------------------
#
# DRY_RUN
#   When true, the system scans, sizes, and logs what it WOULD have done
#   without placing real orders. Set to false only when ready to bet real money.
